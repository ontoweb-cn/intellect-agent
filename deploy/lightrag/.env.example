# LightRAG server — copy to deploy/lightrag/.env and customize.
#
# Prefer generating from your Intellect model config:
#   intellect lightrag sync-server-env [--docker] [--dry-run]
#
# Pin models before first document upload; changing embedding model/dimension
# requires clearing workspace data and re-indexing.

# --- LLM (EXTRACT / QUERY / KEYWORDS) ---
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# --- Embedding ---
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_ASYMMETRIC=false

# --- PostgreSQL (when using docker-compose.webui.yml) ---
POSTGRES_HOST=postgres-lightrag
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lightrag
LIGHTRAG_PG_PASSWORD=change-me

# --- Server ---
WORKSPACE=
PORT=9621
# LIGHTRAG_API_PREFIX=
